<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background" android:gravity="center_vertical">
        <shape android:shape="rectangle">
            <size android:height="6dp" />
            <solid android:color="@color/eink_white" />
            <stroke android:width="1dp" android:color="@color/eink_black" />
        </shape>
    </item>
    <item android:id="@android:id/progress" android:gravity="center_vertical">
        <clip android:clipOrientation="horizontal" android:gravity="left">
            <shape android:shape="rectangle">
                <size android:height="6dp" />
                <solid android:color="@color/eink_black" />
            </shape>
        </clip>
    </item>
</layer-list>
