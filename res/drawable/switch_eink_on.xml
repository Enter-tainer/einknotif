<?xml version="1.0" encoding="utf-8"?>
<!-- 墨水屏开关 - 开启态:实心黑轨道 + 白色滑块靠右。结构与 off 完全一致(轨道 + 滑块),仅填色/位置反转,保证两状态尺寸相同。 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 轨道:实心黑底 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/eink_black" />
            <corners android:radius="0dp" />
            <size android:width="40dp" android:height="24dp" />
        </shape>
    </item>
    <!-- 滑块:白方块,靠右,四周留 2dp 缝 -->
    <item android:left="21dp" android:top="3dp" android:right="3dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/eink_white" />
        </shape>
    </item>
</layer-list>
