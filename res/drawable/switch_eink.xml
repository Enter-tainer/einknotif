<?xml version="1.0" encoding="utf-8"?>
<!-- 墨水屏开关 button drawable:state_checked 切换两个 layer-list(开/关),尺寸完全一致。 -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true"  android:drawable="@drawable/switch_eink_on" />
    <item android:drawable="@drawable/switch_eink_off" />
</selector>
